doctype html
html
  head
    title= title
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      div.container-fluid
        a.navbar-brand(href='/') Oficina de Trotinetes LI4
        button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav')
          span.navbar-toggler-icon
        div.collapse.navbar-collapse#navbarNav
          ul.navbar-nav
            li.nav-item
              a.nav-link(href='/') Home
            li.nav-item
              a.nav-link(href='/funcionarios') Funcionários
            li.nav-item
              a.nav-link(href='/clientes') Clientes
            li.nav-item
              a.nav-link(href='/trotinetes') Trotinetes
            li.nav-item
              a.nav-link(href='/ordens-servico') Ordens Serviço
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(href='#', id='stockDropdown', role='button', data-bs-toggle='dropdown', aria-expanded='false') Stock
              ul.dropdown-menu(aria-labelledby='stockDropdown')
                li: a.dropdown-item(href='/stock') Peças
                li: a.dropdown-item(href='/fornecedores') Fornecedores
                li: a.dropdown-item(href='/encomendas') Listas de Encomendas
                li: a.dropdown-item(href='/devolucoes') Devoluções
            li.nav-item
              a.nav-link(href='/reparacoes') Tabela Reparações
            li.nav-item
              a.nav-link(href='/financas') Finanças

    div.container.mt-4
      block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')